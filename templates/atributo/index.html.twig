{% extends 'base_admin.html.twig' %}

{% block title %}Gestión de Atributos{% endblock %}

{% block body %}
    <main class="flex-1 bg-gradient-to-b from-background-dark to-surface-dark">
        <div class="mx-auto max-w-6xl px-3 py-8 sm:px-4 sm:py-12 lg:px-8">


            <div class="mb-6">
                <a href="{{ path('app_admin_dashboard') }}" class="inline-flex items-center gap-2 rounded-lg bg-slate-900/50 px-3 sm:px-4 py-2 text-xs sm:text-sm font-medium text-slate-300 border border-border-dark hover:bg-primary/10 hover:text-primary hover:border-primary/30 transition-all shadow-sm">
                    <span class="material-symbols-outlined" style="font-size: 16px; min-width: 24px;">grid_view</span>
                    <span class="hidden sm:inline">Volver al Panel de Administración</span>
                    <span class="sm:hidden">Volver</span>
                </a>
            </div>
            
            <!-- Encabezado -->
            <div class="mb-8 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                <div>
                    <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold tracking-tight">Gestión de Atributos</h1>
                    <p class="mt-2 text-xs sm:text-sm text-slate-400">Define las características y variaciones de los productos</p>
                </div>
                <a href="{{ path('app_atributo_new') }}" class="inline-flex items-center justify-center sm:justify-start gap-2 rounded-lg bg-primary px-3 sm:px-4 py-2 font-semibold text-white hover:bg-pink-600 transition-colors text-sm">
                    <span class="material-symbols-outlined">add</span>
                    Nuevo Atributo
                </a>
            </div>

            <!-- Tabla de atributos -->
            {% if atributos|length > 0 %}
                <div class="overflow-x-auto rounded-lg border border-border-dark bg-surface-dark shadow">
                    <table class="w-full divide-y divide-border-dark text-sm">
                        <thead class="bg-slate-900/50 border-b border-border-dark text-xs">
                            <tr>
                                <th class="px-3 sm:px-4 py-3 text-left font-medium uppercase tracking-wider text-slate-300">Nombre</th>
                                <th class="px-3 sm:px-4 py-3 text-left font-medium uppercase tracking-wider text-slate-300 hidden sm:table-cell">Valores</th>
                                <th class="px-3 sm:px-4 py-3 text-center font-medium uppercase tracking-wider text-slate-300">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border-dark">
                            {% for atributo in atributos %}
                                <tr class="hover:bg-slate-900/30 transition-colors">
                                    <td class="px-3 sm:px-4 py-3 whitespace-nowrap font-medium text-xs sm:text-sm">
                                        <div class="max-w-xs truncate">{{ atributo.nombre }}</div>
                                    </td>
                                    <td class="px-3 sm:px-4 py-3 text-xs sm:text-sm text-slate-400 hidden sm:table-cell">
                                        {{ atributo.valores|length }} valor(es)
                                    </td>
                                    <td class="px-3 sm:px-4 py-3 whitespace-nowrap">
                                        <div class="flex justify-center gap-2">
                                            <a href="{{ path('app_atributo_show', {'id': atributo.id}) }}" class="text-primary hover:text-pink-400 transition-colors" title="Ver detalles">
                                                <span class="material-symbols-outlined">visibility</span>
                                            </a>
                                            <a href="{{ path('app_atributo_edit', {'id': atributo.id}) }}" class="text-blue-400 hover:text-blue-300 transition-colors" title="Editar">
                                                <span class="material-symbols-outlined">edit</span>
                                            </a>
                                            <button type="button" class="text-red-400 hover:text-red-300 transition-colors" onclick="confirmDelete('{{ atributo.id }}', '{{ atributo.nombre }}')" title="Eliminar">
                                                <span class="material-symbols-outlined">delete</span>
                                            </button>
                                            <form id="delete-form-{{ atributo.id }}" method="post" action="{{ path('app_atributo_delete', {'id': atributo.id}) }}" style="display: none;">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ atributo.id) }}" />
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="rounded-lg border border-border-dark border-dashed bg-slate-900/30 p-8 sm:p-12 text-center">
                    <span class="material-symbols-outlined text-3xl sm:text-5xl text-slate-600 mb-4 block">inventory_2</span>
                    <h3 class="text-base sm:text-lg font-semibold mb-2">Sin atributos</h3>
                    <p class="text-slate-400 mb-6 text-xs sm:text-sm">Crea tu primer atributo para empezar a definir variaciones de productos.</p>
                    <a href="{{ path('app_atributo_new') }}" class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 font-semibold text-white hover:bg-pink-600 transition-colors text-sm">
                        <span class="material-symbols-outlined">add</span>
                        <span>Crear Primer Atributo</span>
                    </a>
                </div>
            {% endif %}
        </div>
    </main>

    <script>
        function confirmDelete(id, nombre) {
            if (confirm(`¿Estás seguro de que quieres eliminar el atributo "${nombre}"?`)) {
                document.getElementById('delete-form-' + id).submit();
            }
        }
    </script>
{% endblock %}
