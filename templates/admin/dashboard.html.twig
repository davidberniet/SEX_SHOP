{% extends 'base_admin.html.twig' %}

{% block title %}Panel de Administración{% endblock %}

{% block body %}
    <main class="flex-1 bg-gradient-to-b from-background-dark to-surface-dark">
        <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
            <!-- Encabezado -->
            <div class="mb-12">
                <h1 class="text-4xl font-bold tracking-tight mb-2">🎛️ Panel de Administración</h1>
                <p class="text-slate-400">Gestiona todos los aspectos de la tienda de productos adultos</p>
            </div>

            <!-- Grid principal de secciones -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
                
                <!-- PRODUCTOS -->
                <div class="group relative overflow-hidden rounded-xl border border-border-dark bg-surface-dark shadow hover:shadow-lg hover:border-primary transition-all">
                    <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="relative p-8">
                        <div class="inline-flex items-center justify-center w-14 h-14 rounded-lg bg-primary/20 text-primary mb-4">
                            <span class="material-symbols-outlined text-2xl">shopping_bag</span>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Productos</h3>
                        <p class="text-sm text-slate-400 mb-6">Gestiona tu catálogo: precios, imágenes, descripciones</p>
                        
                        <div class="space-y-2">
                            <a href="{{ path('app_producto_index') }}" class="flex items-center gap-2 text-primary hover:text-pink-400 transition-colors">
                                <span class="material-symbols-outlined text-sm">list</span>
                                <span class="text-sm font-semibold">Ver todos</span>
                            </a>
                            <a href="{{ path('app_producto_new') }}" class="flex items-center gap-2 text-green-400 hover:text-green-300 transition-colors">
                                <span class="material-symbols-outlined text-sm">add_circle</span>
                                <span class="text-sm font-semibold">Crear nuevo</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- CATEGORÍAS -->
                <div class="group relative overflow-hidden rounded-xl border border-border-dark bg-surface-dark shadow hover:shadow-lg hover:border-blue-500 transition-all">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="relative p-8">
                        <div class="inline-flex items-center justify-center w-14 h-14 rounded-lg bg-blue-900/30 text-blue-400 mb-4">
                            <span class="material-symbols-outlined text-2xl">folder_open</span>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Categorías</h3>
                        <p class="text-sm text-slate-400 mb-6">Organiza productos en categorías temáticas</p>
                        
                        <div class="space-y-2">
                            <a href="{{ path('app_categoria_index') }}" class="flex items-center gap-2 text-blue-400 hover:text-blue-300 transition-colors">
                                <span class="material-symbols-outlined text-sm">list</span>
                                <span class="text-sm font-semibold">Ver todas</span>
                            </a>
                            <a href="{{ path('app_categoria_new') }}" class="flex items-center gap-2 text-green-400 hover:text-green-300 transition-colors">
                                <span class="material-symbols-outlined text-sm">add_circle</span>
                                <span class="text-sm font-semibold">Crear nueva</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- ATRIBUTOS -->
                <div class="group relative overflow-hidden rounded-xl border border-border-dark bg-surface-dark shadow hover:shadow-lg hover:border-purple-500 transition-all">
                    <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="relative p-8">
                        <div class="inline-flex items-center justify-center w-14 h-14 rounded-lg bg-purple-900/30 text-purple-400 mb-4">
                            <span class="material-symbols-outlined text-2xl">tune</span>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Atributos</h3>
                        <p class="text-sm text-slate-400 mb-6">Define variaciones: Color, Tamaño, Intensidad, etc</p>
                        
                        <div class="space-y-2">
                            <a href="{{ path('app_atributo_index') }}" class="flex items-center gap-2 text-purple-400 hover:text-purple-300 transition-colors">
                                <span class="material-symbols-outlined text-sm">list</span>
                                <span class="text-sm font-semibold">Ver todos</span>
                            </a>
                            <a href="{{ path('app_atributo_new') }}" class="flex items-center gap-2 text-green-400 hover:text-green-300 transition-colors">
                                <span class="material-symbols-outlined text-sm">add_circle</span>
                                <span class="text-sm font-semibold">Crear nuevo</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- VARIACIONES/COMBINACIONES -->
                <div class="group relative overflow-hidden rounded-xl border border-border-dark bg-surface-dark shadow hover:shadow-lg hover:border-orange-500 transition-all">
                    <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="relative p-8">
                        <div class="inline-flex items-center justify-center w-14 h-14 rounded-lg bg-orange-900/30 text-orange-400 mb-4">
                            <span class="material-symbols-outlined text-2xl">inventory_2</span>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Variaciones</h3>
                        <p class="text-sm text-slate-400 mb-6">Gestiona combinaciones, SKU, precios y stock</p>
                        
                        <div class="space-y-2">
                            <a href="{{ path('app_producto_index') }}" class="flex items-center gap-2 text-orange-400 hover:text-orange-300 transition-colors">
                                <span class="material-symbols-outlined text-sm">manage_history</span>
                                <span class="text-sm font-semibold">Ver por producto</span>
                            </a>
                            <a href="{{ path('app_producto_index') }}" class="flex items-center gap-2 text-slate-400 hover:text-slate-300 transition-colors">
                                <span class="material-symbols-outlined text-sm">info</span>
                                <span class="text-sm font-semibold">Accede desde Productos</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- DATOS DE PRUEBA -->
                <div class="group relative overflow-hidden rounded-xl border border-border-dark bg-surface-dark shadow hover:shadow-lg hover:border-yellow-500 transition-all">
                    <div class="absolute inset-0 bg-gradient-to-br from-yellow-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="relative p-8">
                        <div class="inline-flex items-center justify-center w-14 h-14 rounded-lg bg-yellow-900/30 text-yellow-400 mb-4">
                            <span class="material-symbols-outlined text-2xl">database</span>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Datos de Prueba</h3>
                        <p class="text-sm text-slate-400 mb-6">Carga datos de ejemplo para probar la tienda</p>
                        
                        <div class="space-y-2">
                            <a href="{{ path('seed_data') }}" class="flex items-center gap-2 text-yellow-400 hover:text-yellow-300 transition-colors">
                                <span class="material-symbols-outlined text-sm">refresh</span>
                                <span class="text-sm font-semibold">Cargar ejemplos</span>
                            </a>
                            <div class="flex items-center gap-2 text-slate-500">
                                <span class="material-symbols-outlined text-sm">check</span>
                                <span class="text-sm font-semibold">Ya cargados</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- FRONTEND -->
                <div class="group relative overflow-hidden rounded-xl border border-border-dark bg-surface-dark shadow hover:shadow-lg hover:border-green-500 transition-all">
                    <div class="absolute inset-0 bg-gradient-to-br from-green-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    <div class="relative p-8">
                        <div class="inline-flex items-center justify-center w-14 h-14 rounded-lg bg-green-900/30 text-green-400 mb-4">
                            <span class="material-symbols-outlined text-2xl">storefront</span>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Tienda Pública</h3>
                        <p class="text-sm text-slate-400 mb-6">Visualiza cómo ven los clientes tu tienda</p>
                        
                        <div class="space-y-2">
                            <a href="/" class="flex items-center gap-2 text-green-400 hover:text-green-300 transition-colors">
                                <span class="material-symbols-outlined text-sm">open_in_new</span>
                                <span class="text-sm font-semibold">Ver tienda</span>
                            </a>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Sección de resumen rápido -->
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-12">
                <div class="rounded-lg border border-border-dark bg-surface-dark p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs text-slate-400 font-semibold mb-2">📦 PRODUCTOS</p>
                            <p class="text-2xl font-bold text-primary">{{ productos_count }}</p>
                        </div>
                        <span class="material-symbols-outlined text-3xl text-primary/20">shopping_bag</span>
                    </div>
                </div>
                <div class="rounded-lg border border-border-dark bg-surface-dark p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs text-slate-400 font-semibold mb-2">📁 CATEGORÍAS</p>
                            <p class="text-2xl font-bold text-blue-400">{{ categorias_count }}</p>
                        </div>
                        <span class="material-symbols-outlined text-3xl text-blue-400/20">folder_open</span>
                    </div>
                </div>
                <div class="rounded-lg border border-border-dark bg-surface-dark p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs text-slate-400 font-semibold mb-2">⚙️ ATRIBUTOS</p>
                            <p class="text-2xl font-bold text-purple-400">{{ atributos_count }}</p>
                        </div>
                        <span class="material-symbols-outlined text-3xl text-purple-400/20">tune</span>
                    </div>
                </div>
                <div class="rounded-lg border border-border-dark bg-surface-dark p-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-xs text-slate-400 font-semibold mb-2">📊 VARIACIONES</p>
                            <p class="text-2xl font-bold text-orange-400">{{ variaciones_count }}</p>
                        </div>
                        <span class="material-symbols-outlined text-3xl text-orange-400/20">inventory_2</span>
                    </div>
                </div>
            </div>

            <!-- Guía rápida -->
            <div class="rounded-lg border border-border-dark bg-surface-dark p-8">
                <h2 class="text-2xl font-bold text-white mb-6">📚 Guía Rápida</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <h3 class="text-lg font-semibold text-primary mb-3">1️⃣ Crear Producto</h3>
                        <ol class="space-y-2 text-sm text-slate-300">
                            <li>• Ir a <strong>Productos → Crear nuevo</strong></li>
                            <li>• Rellenar nombre, descripción, precio</li>
                            <li>• Seleccionar categoría</li>
                            <li>• Agregar imagen (URL)</li>
                            <li>• Guardar</li>
                        </ol>
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold text-primary mb-3">2️⃣ Agregar Variaciones</h3>
                        <ol class="space-y-2 text-sm text-slate-300">
                            <li>• Ir a <strong>Productos → Ver detalles</strong></li>
                            <li>• En sección "Variaciones" click en <strong>Gestionar</strong></li>
                            <li>• Click en <strong>Nueva Variación</strong></li>
                            <li>• Rellenar SKU, precio, stock, atributos</li>
                            <li>• Guardar</li>
                        </ol>
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold text-primary mb-3">3️⃣ Crear Atributos</h3>
                        <ol class="space-y-2 text-sm text-slate-300">
                            <li>• Ir a <strong>Atributos → Crear nuevo</strong></li>
                            <li>• Poner nombre (ej: Color)</li>
                            <li>• Agregar valores (Rojo, Negro, etc)</li>
                            <li>• Click agregar valor para más opciones</li>
                            <li>• Guardar</li>
                        </ol>
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold text-primary mb-3">4️⃣ Controlar Stock</h3>
                        <ol class="space-y-2 text-sm text-slate-300">
                            <li>• Cada variación tiene stock independiente</li>
                            <li>• Editar variación para cambiar cantidad</li>
                            <li>• Sistema muestra: <strong>En Stock / Agotado</strong></li>
                            <li>• Stock se reduce con cada compra</li>
                        </ol>
                    </div>
                </div>
            </div>

        </div>
    </main>
{% endblock %}
