{% extends 'base_admin.html.twig' %}

{% block title %}Gestión de Productos{% endblock %}

{% block body %}
    <main class="flex-1 bg-gradient-to-b from-background-dark to-surface-dark">
        <div class="mx-auto max-w-7xl px-3 py-8 sm:px-4 sm:py-12 lg:px-8">

            <div class="mb-6">
                <a href="{{ path('app_admin_dashboard') }}" class="inline-flex items-center gap-2 rounded-lg bg-slate-900/50 px-3 sm:px-4 py-2 text-xs sm:text-sm font-medium text-slate-300 border border-border-dark hover:bg-primary/10 hover:text-primary hover:border-primary/30 transition-all shadow-sm">
                    <span class="material-symbols-outlined" style="font-size: 16px; min-width: 24px;">grid_view</span>
                    <span class="hidden sm:inline">Volver al Panel de Administración</span>
                    <span class="sm:hidden">Volver</span>
                </a>
            </div>
            
            <!-- Encabezado -->
            <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div>
                    <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold tracking-tight">Gestión de Productos</h1>
                    <p class="mt-2 text-xs sm:text-sm text-slate-400">{{ productos|length }} producto(s) encontrado(s)</p>
                </div>
                <a href="{{ path('app_producto_new') }}" class="inline-flex items-center justify-center sm:justify-start gap-2 rounded-lg bg-primary px-3 sm:px-4 py-2 font-semibold text-white hover:bg-pink-600 transition-colors text-sm">
                    <span class="material-symbols-outlined">add</span>
                    Nuevo Producto
                </a>
            </div>

            <!-- Filtros de Búsqueda -->
            <div class="mb-8 rounded-lg border border-border-dark bg-surface-dark p-4 sm:p-6 shadow">
                <form method="get" class="space-y-4">
                    <div class="grid grid-cols-1 gap-3 sm:gap-4 sm:grid-cols-2 lg:grid-cols-5">
                        <!-- Búsqueda por nombre -->
                        <input type="text" name="nombre" value="{{ filtros.nombre }}" placeholder="Buscar por nombre..." class="rounded-lg border border-border-dark bg-slate-900/50 px-3 py-2 text-xs sm:text-sm text-slate-100 placeholder-slate-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors">
                        
                        <!-- Precio mínimo -->
                        <input type="number" name="minPrice" value="{{ filtros.minPrice }}" placeholder="Precio mín." min="0" step="0.01" class="rounded-lg border border-border-dark bg-slate-900/50 px-3 py-2 text-xs sm:text-sm text-slate-100 placeholder-slate-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors">
                        
                        <!-- Precio máximo -->
                        <input type="number" name="maxPrice" value="{{ filtros.maxPrice }}" placeholder="Precio máx." min="0" step="0.01" class="rounded-lg border border-border-dark bg-slate-900/50 px-3 py-2 text-xs sm:text-sm text-slate-100 placeholder-slate-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors">
                        
                        <!-- Ordenamiento -->
                        <select name="orderBy" class="rounded-lg border border-border-dark bg-slate-900/50 px-3 py-2 text-xs sm:text-sm text-slate-100 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors">
                            <option value="nombre" {{ filtros.orderBy == 'nombre' ? 'selected' : '' }}>Ordenar por nombre</option>
                            <option value="precio" {{ filtros.orderBy == 'precio' ? 'selected' : '' }}>Ordenar por precio</option>
                            <option value="id" {{ filtros.orderBy == 'id' ? 'selected' : '' }}>Más recientes</option>
                        </select>

                        <!-- Dirección ordenamiento -->
                        <select name="orderDir" class="rounded-lg border border-border-dark bg-slate-900/50 px-3 py-2 text-xs sm:text-sm text-slate-100 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors">
                            <option value="ASC" {{ filtros.orderDir == 'ASC' ? 'selected' : '' }}>Ascendente</option>
                            <option value="DESC" {{ filtros.orderDir == 'DESC' ? 'selected' : '' }}>Descendente</option>
                        </select>
                    </div>
                    
                    <div class="flex gap-3 col-span-1 sm:col-span-2 lg:col-span-5">
                        <button type="submit" class="flex-1 inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-3 sm:px-4 py-2 font-semibold text-white hover:bg-pink-600 transition-colors text-sm">
                            <span class="material-symbols-outlined">search</span>
                            <span class="hidden sm:inline">Buscar</span>
                        </button>
                        <a href="{{ path('app_producto_index') }}" class="flex-1 inline-flex items-center justify-center gap-2 rounded-lg border border-border-dark px-3 sm:px-4 py-2 font-semibold text-slate-300 hover:bg-slate-900/50 transition-colors text-sm">
                            <span class="material-symbols-outlined">clear</span>
                            <span class="hidden sm:inline">Limpiar</span>
                        </a>
                    </div>
                </form>
            </div>

            <!-- Tabla de Productos -->
            {% if productos|length > 0 %}
                <div class="overflow-x-auto rounded-lg border border-border-dark bg-surface-dark shadow">
                    <table class="w-full divide-y divide-border-dark text-sm">
                        <thead class="bg-slate-900/50 text-xs">
                            <tr>
                                <th class="px-3 sm:px-4 py-3 text-left font-medium uppercase tracking-wider text-slate-300">Imagen</th>
                                <th class="px-3 sm:px-4 py-3 text-left font-medium uppercase tracking-wider text-slate-300">Nombre</th>
                                <th class="px-3 sm:px-4 py-3 text-left font-medium uppercase tracking-wider text-slate-300 hidden sm:table-cell">Categoría</th>
                                <th class="px-3 sm:px-4 py-3 text-left font-medium uppercase tracking-wider text-slate-300">Precio</th>
                                <th class="px-3 sm:px-4 py-3 text-left font-medium uppercase tracking-wider text-slate-300 hidden lg:table-cell">Estado</th>
                                <th class="px-3 sm:px-4 py-3 text-center font-medium uppercase tracking-wider text-slate-300">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border-dark">
                            {% for producto in productos %}
                                <tr class="hover:bg-slate-900/30 transition-colors">
                                    <!-- Imagen -->
                                    <td class="px-3 sm:px-4 py-3">
                                        {% if producto.imagenUrl %}
                                            <img src="{{ producto.imagenUrl }}" alt="{{ producto.nombre }}" class="h-8 sm:h-10 w-8 sm:w-10 rounded object-cover">
                                        {% else %}
                                            <div class="h-8 sm:h-10 w-8 sm:w-10 rounded bg-slate-700 flex items-center justify-center">
                                                <span class="material-symbols-outlined text-slate-500" style="font-size: 16px;">image</span>
                                            </div>
                                        {% endif %}
                                    </td>

                                    <!-- Nombre -->
                                    <td class="px-3 sm:px-4 py-3 font-medium text-xs sm:text-sm">
                                        <div class="max-w-xs truncate">{{ producto.nombre }}</div>
                                    </td>

                                    <!-- Categoría (hidden en móvil) -->
                                    <td class="px-3 sm:px-4 py-3 text-xs sm:text-sm text-slate-400 hidden sm:table-cell">
                                        {% if producto.categoria %}
                                            <div class="max-w-xs truncate">{{ producto.categoria.nombre }}</div>
                                        {% else %}
                                            <span class="text-slate-600">Sin categoría</span>
                                        {% endif %}
                                    </td>

                                    <!-- Precio -->
                                    <td class="px-3 sm:px-4 py-3 font-semibold text-primary text-xs sm:text-sm">
                                        {{ producto.precio ? '€' ~ producto.precio : 'N/A' }}
                                    </td>

                                    <!-- Estado (hidden en móvil) -->
                                    <td class="px-3 sm:px-4 py-3 text-xs hidden lg:table-cell">
                                        {% if producto.activo %}
                                            <span class="inline-flex items-center gap-1 rounded-full bg-green-900/30 px-2 sm:px-3 py-1 text-xs font-medium text-green-400">
                                                <span class="material-symbols-outlined" style="font-size: 12px;">check_circle</span>
                                                <span class="hidden sm:inline">Activo</span>
                                            </span>
                                        {% else %}
                                            <span class="inline-flex items-center gap-1 rounded-full bg-slate-700/30 px-2 sm:px-3 py-1 text-xs font-medium text-slate-400">
                                                <span class="material-symbols-outlined" style="font-size: 12px;">cancel</span>
                                                <span class="hidden sm:inline">Inactivo</span>
                                            </span>
                                        {% endif %}
                                    </td>

                                    <!-- Acciones -->
                                    <td class="px-3 sm:px-4 py-3">
                                        <div class="flex items-center justify-center gap-2">
                                            <a href="{{ path('app_producto_show', {'id': producto.id}) }}" class="text-slate-400 hover:text-primary transition-colors" title="Ver">
                                                <span class="material-symbols-outlined">visibility</span>
                                            </a>
                                            <a href="{{ path('app_producto_edit', {'id': producto.id}) }}" class="text-slate-400 hover:text-primary transition-colors" title="Editar">
                                                <span class="material-symbols-outlined">edit</span>
                                            </a>
                                            <form method="POST" action="{{ path('app_producto_delete', {'id': producto.id}) }}" style="display:inline;" onsubmit="return confirm('¿Eliminar este producto?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ producto.id) }}">
                                                <button type="submit" class="text-slate-400 hover:text-red-500 transition-colors" title="Eliminar" style="background:none; border:none; cursor:pointer;">
                                                    <span class="material-symbols-outlined">delete</span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>8 sm:p-12 text-center">
                    <span class="material-symbols-outlined mx-auto block mb-4 text-3xl sm:text-4xl text-slate-600">inbox</span>
                    <p class="text-slate-400 mb-4 text-sm sm:text-base">No hay productos disponibles</p>
                    <a href="{{ path('app_producto_new') }}" class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 font-semibold text-white hover:bg-pink-600 transition-colors text-sm">
                        <span class="material-symbols-outlined">add</span>
                        <span>Crear primer producto</span>ducto_new') }}" class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 font-semibold text-white hover:bg-pink-600 transition-colors">
                        <span class="material-symbols-outlined">add</span>
                        Crear primer producto
                    </a>
                </div>
            {% endif %}
        </div>
    </main>
{% endblock %}
